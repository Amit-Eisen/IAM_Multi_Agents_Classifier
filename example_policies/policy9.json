{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PrivilegeEscalationPath",
      "Effect": "Allow",
      "Action": [
        "lambda:CreateFunction",
        "lambda:InvokeFunction",
        "iam:PassRole"
      ],
      "Resource": "*"
    },
    {
      "Sid": "EC2WithRoleAssumption",
      "Effect": "Allow",
      "Action": [
        "ec2:RunInstances",
        "iam:PassRole"
      ],
      "Resource": "*"
    }
  ]
}
